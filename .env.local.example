# Copia este archivo a .env.local y llena con tus valores reales de Supabase
# (Project Settings > API en tu dashboard de Supabase)

NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-publica

# Solo se usa en el servidor (Route Handlers / Server Actions), nunca se expone al cliente
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
